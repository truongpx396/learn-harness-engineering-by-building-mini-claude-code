# =============================================================================
#  All agents use the OpenAI chat-completions protocol (openai Python SDK).
#  Set OPENAI_API_KEY + MODEL_ID + OPENAI_BASE_URL for your chosen provider.
#
#  Copy this file to .env and uncomment the block for your provider.
# =============================================================================

# =============================================================================
#  ☁️  Cloud providers
# =============================================================================

# ---- OpenAI (default) -------------------------------------------------------
OPENAI_API_KEY=sk-xxx
MODEL_ID=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1   # (default, can omit)

# ---- GitHub Models ----------------------------------------------------------
# OPENAI_API_KEY=github_pat_xxx
# MODEL_ID=gpt-4o
# OPENAI_BASE_URL=https://models.inference.ai.azure.com

# ---- Azure OpenAI -----------------------------------------------------------
# OPENAI_API_KEY=xxx
# MODEL_ID=gpt-4o
# OPENAI_BASE_URL=https://<your-resource>.openai.azure.com/openai/deployments/<deployment>

# ---- DeepSeek ---------------------------------------------------------------
# OPENAI_API_KEY=sk-xxx
# MODEL_ID=deepseek-chat
# OPENAI_BASE_URL=https://api.deepseek.com/v1

# ---- Kimi (Moonshot) --------------------------------------------------------
# OPENAI_API_KEY=sk-xxx
# MODEL_ID=moonshot-v1-8k
# OPENAI_BASE_URL=https://api.moonshot.cn/v1

# =============================================================================
#  💻  Local servers (no cloud API key required)
# =============================================================================

# ---- LM Studio --------------------------------------------------------------
#  1. Open LM Studio → Developer tab → load a model → Start Server
#  2. Copy the model identifier shown (e.g. lmstudio-community/Qwen2.5-7B-Instruct-GGUF)
# OPENAI_API_KEY=lm-studio
# MODEL_ID=lmstudio-community/Qwen2.5-7B-Instruct-GGUF
# OPENAI_BASE_URL=http://localhost:1234/v1

# ---- Ollama -----------------------------------------------------------------
#  1. ollama pull qwen2.5:7b
#  2. ollama serve
# OPENAI_API_KEY=ollama
# MODEL_ID=qwen2.5:7b
# OPENAI_BASE_URL=http://localhost:11434/v1

# ---- GPT4All ----------------------------------------------------------------
#  1. Download GPT4All desktop app → Settings → API Server → Enable
# OPENAI_API_KEY=gpt4all
# MODEL_ID=Mistral 7B Instruct
# OPENAI_BASE_URL=http://localhost:4891/v1
# MODEL_ID=deepseek-chat
